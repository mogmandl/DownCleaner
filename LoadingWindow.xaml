<Window x:Class="FileCleaner.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="DownCleaner 시작 중"
        Width="460"
        Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True">
    <Window.TaskbarItemInfo>
        <shell:TaskbarItemInfo ProgressState="Normal" ProgressValue="0"/>
    </Window.TaskbarItemInfo>

    <Border Background="#171A21"
            BorderBrush="#343B48"
            BorderThickness="1"
            CornerRadius="8"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="DownCleaner"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#F3F6FA"/>
            <TextBlock Grid.Row="1"
                       Text="즐겨찾기 폴더를 미리 분석하는 중입니다."
                       Margin="0,8,0,0"
                       Foreground="#AEB7C4"
                       FontSize="13"/>
            <ProgressBar x:Name="LoadingProgressBar"
                         Grid.Row="2"
                         Height="12"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         Foreground="#60CDFF"
                         Background="#252A33"
                         IsIndeterminate="False"
                         VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText"
                       Grid.Row="3"
                       Text="시작 준비 중..."
                       Foreground="#AEB7C4"
                       FontSize="12"
                       TextWrapping="Wrap"/>
        </Grid>
    </Border>
</Window>
