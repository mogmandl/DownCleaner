<Window x:Class="FileCleaner.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DownCleaner 시작 중"
        Width="460"
        Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border Background="White"
            BorderBrush="#DADADA"
            BorderThickness="1"
            CornerRadius="8"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="DownCleaner"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#222"/>
            <TextBlock Grid.Row="1"
                       Text="즐겨찾기 폴더를 미리 분석하는 중입니다."
                       Margin="0,8,0,0"
                       Foreground="#555"
                       FontSize="13"/>
            <ProgressBar Grid.Row="2"
                         Height="12"
                         IsIndeterminate="True"
                         VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText"
                       Grid.Row="3"
                       Text="시작 준비 중..."
                       Foreground="#666"
                       FontSize="12"
                       TextWrapping="Wrap"/>
        </Grid>
    </Border>
</Window>
