<Window x:Class="FileCleaner.MainWindow"
        Icon="img/DownCleanerIcon.ico"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:FileCleaner.Models"
        xmlns:vm="clr-namespace:FileCleaner.ViewModels"
        Title="DownCleaner"
        Height="780"
        Width="1280"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Color x:Key="AppBgColor">#0F1117</Color>
        <Color x:Key="SurfaceColor">#171A21</Color>
        <Color x:Key="SurfaceAltColor">#20242C</Color>
        <Color x:Key="ControlColor">#252A33</Color>
        <Color x:Key="ControlHoverColor">#303744</Color>
        <Color x:Key="ControlPressedColor">#384151</Color>
        <Color x:Key="BorderColor">#343B48</Color>
        <Color x:Key="TextPrimaryColor">#F3F6FA</Color>
        <Color x:Key="TextSecondaryColor">#AEB7C4</Color>
        <Color x:Key="AccentColor">#60CDFF</Color>
        <Color x:Key="DangerColor">#E5484D</Color>
        <Color x:Key="WarningSurfaceColor">#2E2817</Color>
        <Color x:Key="DangerSurfaceColor">#321B1F</Color>

        <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource AppBgColor}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}"/>
        <SolidColorBrush x:Key="ControlBrush" Color="{StaticResource ControlColor}"/>
        <SolidColorBrush x:Key="ControlHoverBrush" Color="{StaticResource ControlHoverColor}"/>
        <SolidColorBrush x:Key="ControlPressedBrush" Color="{StaticResource ControlPressedColor}"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
        <SolidColorBrush x:Key="WarningSurfaceBrush" Color="{StaticResource WarningSurfaceColor}"/>
        <SolidColorBrush x:Key="DangerSurfaceBrush" Color="{StaticResource DangerSurfaceColor}"/>

        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InfoTextBrushKey}" Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="{StaticResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{StaticResource SurfaceColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="{StaticResource ControlColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="{StaticResource SurfaceAltColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#26384A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{StaticResource ControlHoverColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{StaticResource TextPrimaryColor}"/>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ControlHoverBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ControlPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="{StaticResource AppBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,3,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource SurfaceBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TreeView}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style TargetType="{x:Type TreeViewItem}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="Padding" Value="8,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#26384A"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource ControlHoverBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#26384A"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style TargetType="{x:Type ToolBar}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Background" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="Margin" Value="6,2"/>
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ControlHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#26384A"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <Style TargetType="{x:Type ProgressBar}">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
        </Style>

        <Style TargetType="{x:Type Thumb}">
            <Setter Property="Background" Value="#667083"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarTrackButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="MinWidth" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Orientation="{TemplateBinding Orientation}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource ScrollBarTrackButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource ScrollBarTrackButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="12"/>
                                <Setter Property="MinHeight" Value="12"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="MinWidth" Value="0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ControlBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ControlHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#26384A"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CleanupTreeToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2">
                            <TextBlock x:Name="Glyph"
                                       Text="+"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Glyph" Property="Text" Value="-"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource ControlHoverBrush}"/>
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Glyph" Property="Text" Value=""/>
                                <Setter TargetName="ToggleBorder" Property="Background" Value="Transparent"/>
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CleanupTreeViewItemStyle" TargetType="{x:Type TreeViewItem}">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TreeViewItem}">
                        <StackPanel>
                            <Border x:Name="HeaderBorder"
                                    Background="Transparent"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#26384A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FolderGlyphStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Text" Value="📁"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                    <Setter Property="Text" Value="📂"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CleanupNodeGlyphStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Text" Value="📄"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter Property="Text" Value="📁"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsFolder}" Value="True"/>
                        <Condition Binding="{Binding IsExpanded}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Text" Value="📂"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" Padding="6,5" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}">
            <Button Command="{Binding AddFolderCommand}" Padding="10,4" Content="폴더 추가"/>
            <Button Command="{Binding RefreshCommand}" Padding="10,4" Content="새로고침"/>
            <Separator/>
            <Button Command="{Binding AnalyzeStorageCommand}" Padding="10,4" Content="저장공간 분석"/>
        </ToolBar>

        <TabControl Grid.Row="1" SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="파일 탐색기">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="270" MinWidth="150"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,1,0">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceAltBrush}" Padding="10,7">
                                <TextBlock Text="폴더 목록" FontWeight="SemiBold"/>
                            </Border>
                            <TreeView x:Name="FolderTreeView"
                                      ItemsSource="{Binding RootNodes}"
                                      SelectedItemChanged="FolderTreeView_SelectedItemChanged"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.PanningMode="VerticalOnly"
                                      BorderThickness="0"
                                      Padding="2">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate DataType="{x:Type models:FolderNode}" ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Margin="2,2">
                                            <TextBlock Style="{StaticResource FolderGlyphStyle}"/>
                                            <TextBlock Text="{Binding Name}"/>
                                            <Border Background="{StaticResource AccentBrush}"
                                                    CornerRadius="3"
                                                    Margin="6,0,0,0"
                                                    Padding="4,1"
                                                    Visibility="{Binding IsProjectFolder, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding ProjectType}" Foreground="#06131A" FontSize="9"/>
                                            </Border>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrushDark}"/>

                    <DockPanel Grid.Column="2">
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource SurfaceAltBrush}"
                                Padding="6,5"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <WrapPanel>
                                    <Button Command="{Binding SelectAllCommand}" Content="전체 선택" Padding="7,3" Margin="0,0,4,0"/>
                                    <Button Command="{Binding SelectDangerousCommand}" Content="삭제 후보 선택" Padding="7,3" Margin="0,0,4,0"/>
                                    <Button Command="{Binding DeselectAllCommand}" Content="선택 해제" Padding="7,3" Margin="0,0,10,0"/>
                                    <Button Command="{Binding AddToDeleteListCommand}"
                                            Content="삭제 목록에 추가"
                                            Background="{StaticResource DangerBrush}"
                                            Foreground="White"
                                            Padding="7,3"/>
                                    <TextBlock Text="{Binding SelectedInfo}"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"/>
                                </WrapPanel>
                                <TextBlock Text="자동 추천은 기본 위험도와 사용자의 삭제 이력을 함께 반영합니다."
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="340" MinWidth="260"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,0,1" Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="220"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="선택" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="폴더 / 파일" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="크기" FontWeight="SemiBold" Margin="6,0,0,0"/>
                                        <TextBlock Grid.Column="3" Text="위험도" FontWeight="SemiBold" Margin="6,0,0,0"/>
                                        <TextBlock Grid.Column="4" Text="정보" FontWeight="SemiBold" Margin="6,0,0,0"/>
                                    </Grid>
                                </Border>

                                <TreeView Grid.Row="1"
                                          x:Name="CurrentCleanupTreeView"
                                          ItemsSource="{Binding CurrentCleanupNodes}"
                                          SelectedItemChanged="CurrentCleanupTreeView_SelectedItemChanged"
                                          MouseDoubleClick="CurrentCleanupTreeView_MouseDoubleClick"
                                          PreviewMouseRightButtonDown="CleanupTreeView_PreviewMouseRightButtonDown"
                                          VirtualizingStackPanel.IsVirtualizing="True"
                                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          ScrollViewer.PanningMode="VerticalOnly"
                                          BorderThickness="0"
                                          Padding="4">
                                    <TreeView.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="열기" Click="OpenSelectedPath_Click"/>
                                            <MenuItem Header="파일 탐색기에서 보기" Click="ShowSelectedInExplorer_Click"/>
                                            <MenuItem Header="경로 복사" Click="CopySelectedPath_Click"/>
                                            <Separator/>
                                            <MenuItem Header="삭제 목록에 추가" Click="AddSelectedNodeToDeleteList_Click"/>
                                        </ContextMenu>
                                    </TreeView.ContextMenu>
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource CleanupTreeViewItemStyle}"/>
                                    </TreeView.ItemContainerStyle>
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate DataType="{x:Type models:CleanupNode}" ItemsSource="{Binding Children}">
                                            <Grid Margin="0,2" HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="96"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="220"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" MinWidth="0" Margin="{Binding IndentMargin}">
                                                    <ToggleButton Style="{StaticResource CleanupTreeToggleStyle}"
                                                                  IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                                  IsEnabled="{Binding IsExpandable}"/>
                                                    <TextBlock Style="{StaticResource CleanupNodeGlyphStyle}"/>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding SizeDisplay}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Right"
                                                           Margin="6,0,0,0"/>

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding File.RiskDisplay}"
                                                           Foreground="{Binding File.RiskBrush}"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="6,0,0,0"/>

                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding DetailText}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="6,0,0,0"/>
                                            </Grid>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </Grid>

                            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrushDark}"/>

                            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1,0,0,0" Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="선택 항목 미리보기" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                    <Border Grid.Row="1" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="6">
                                        <Grid>
                                            <Image Source="{Binding PreviewImage}"
                                                   Stretch="Uniform"
                                                   Visibility="{Binding IsPreviewAvailable, Converter={StaticResource BoolToVis}}"/>
                                            <ScrollViewer Visibility="{Binding IsTextPreviewAvailable, Converter={StaticResource BoolToVis}}"
                                                          HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Auto">
                                                <TextBox Text="{Binding PreviewText}"
                                                         IsReadOnly="True"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         FontFamily="Consolas"
                                                         FontSize="12"
                                                         TextWrapping="NoWrap"
                                                         AcceptsReturn="True"
                                                         AcceptsTab="True"/>
                                            </ScrollViewer>
                                            <Border Background="Transparent"
                                                    Visibility="{Binding IsModelPreviewAvailable, Converter={StaticResource BoolToVis}}"
                                                    MouseDown="PreviewViewport_MouseDown"
                                                    MouseMove="PreviewViewport_MouseMove"
                                                    MouseUp="PreviewViewport_MouseUp"
                                                    MouseLeave="PreviewViewport_MouseUp"
                                                    MouseWheel="PreviewViewport_MouseWheel">
                                                <Viewport3D>
                                                    <Viewport3D.Camera>
                                                        <PerspectiveCamera Position="{Binding PreviewCameraPosition}"
                                                                           LookDirection="{Binding PreviewCameraLookDirection}"
                                                                           UpDirection="0,1,0"
                                                                           FieldOfView="45"/>
                                                    </Viewport3D.Camera>
                                                    <ModelVisual3D Content="{Binding PreviewModel}"/>
                                                </Viewport3D>
                                            </Border>
                                            <Button Content="시점 초기화"
                                                    Padding="6,3"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,4,4,0"
                                                    Click="ResetPreviewCamera_Click"
                                                    Visibility="{Binding IsModelPreviewAvailable, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{Binding PreviewMessage}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       IsHitTestVisible="False"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                        <TextBlock Text="{Binding SelectedEntryName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedEntryPath}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedEntryInfo}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedEntryDetail}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="삭제 목록 ("/>
                        <TextBlock Text="{Binding DeleteList.Count}" Foreground="{StaticResource DangerBrush}" FontWeight="Bold"/>
                        <TextBlock Text=")"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource WarningSurfaceBrush}" Padding="10,7" BorderBrush="#6B5722" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="목록 초기화" Command="{Binding ClearDeleteListCommand}" Padding="8,3"/>
                            <TextBlock Text="{Binding DeleteListSummary}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="13"/>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="340" MinWidth="260"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,0,1" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="선택" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="출처 폴더 / 파일" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="크기" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="위험도" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="4" Text="정보" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>

                        <TreeView Grid.Row="1"
                                  ItemsSource="{Binding DeleteListNodes}"
                                  SelectedItemChanged="CurrentCleanupTreeView_SelectedItemChanged"
                                  PreviewMouseRightButtonDown="CleanupTreeView_PreviewMouseRightButtonDown"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.PanningMode="VerticalOnly"
                                  BorderThickness="0"
                                  Padding="4">
                            <TreeView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="열기" Click="OpenSelectedPath_Click"/>
                                    <MenuItem Header="파일 탐색기에서 보기" Click="ShowSelectedInExplorer_Click"/>
                                    <MenuItem Header="경로 복사" Click="CopySelectedPath_Click"/>
                                    <Separator/>
                                    <MenuItem Header="삭제 목록에서 제거" Click="RemoveSelectedNodeFromDeleteList_Click"/>
                                </ContextMenu>
                            </TreeView.ContextMenu>
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource CleanupTreeViewItemStyle}"/>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type models:CleanupNode}" ItemsSource="{Binding Children}">
                                    <Grid Margin="0,2" HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="220"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" MinWidth="0" Margin="{Binding IndentMargin}">
                                            <ToggleButton Style="{StaticResource CleanupTreeToggleStyle}"
                                                          IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                          IsEnabled="{Binding IsExpandable}"/>
                                            <TextBlock Style="{StaticResource CleanupNodeGlyphStyle}"/>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding SizeDisplay}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   Margin="6,0,0,0"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding File.RiskDisplay}"
                                                   Foreground="{Binding File.RiskBrush}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="6,0,0,0"/>

                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding DetailText}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="6,0,0,0"/>
                                    </Grid>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                        <GridSplitter Grid.Column="1" Grid.RowSpan="2" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrushDark}"/>

                        <Border Grid.Column="2" Grid.RowSpan="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1,0,0,0" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="삭제 항목 미리보기" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                <Border Grid.Row="1" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="6">
                                    <Grid>
                                        <Image Source="{Binding PreviewImage}"
                                               Stretch="Uniform"
                                               Visibility="{Binding IsPreviewAvailable, Converter={StaticResource BoolToVis}}"/>
                                        <ScrollViewer Visibility="{Binding IsTextPreviewAvailable, Converter={StaticResource BoolToVis}}"
                                                      HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                            <TextBox Text="{Binding PreviewText}"
                                                     IsReadOnly="True"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     FontFamily="Consolas"
                                                     FontSize="12"
                                                     TextWrapping="NoWrap"
                                                     AcceptsReturn="True"
                                                     AcceptsTab="True"/>
                                        </ScrollViewer>
                                        <Border Background="Transparent"
                                                Visibility="{Binding IsModelPreviewAvailable, Converter={StaticResource BoolToVis}}"
                                                MouseDown="PreviewViewport_MouseDown"
                                                MouseMove="PreviewViewport_MouseMove"
                                                MouseUp="PreviewViewport_MouseUp"
                                                MouseLeave="PreviewViewport_MouseUp"
                                                MouseWheel="PreviewViewport_MouseWheel">
                                            <Viewport3D>
                                                <Viewport3D.Camera>
                                                    <PerspectiveCamera Position="{Binding PreviewCameraPosition}"
                                                                       LookDirection="{Binding PreviewCameraLookDirection}"
                                                                       UpDirection="0,1,0"
                                                                       FieldOfView="45"/>
                                                </Viewport3D.Camera>
                                                <ModelVisual3D Content="{Binding PreviewModel}"/>
                                            </Viewport3D>
                                        </Border>
                                        <Button Content="시점 초기화"
                                                Padding="6,3"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,4,4,0"
                                                Click="ResetPreviewCamera_Click"
                                                Visibility="{Binding IsModelPreviewAvailable, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding PreviewMessage}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   IsHitTestVisible="False"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding SelectedEntryName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SelectedEntryPath}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SelectedEntryInfo}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SelectedEntryDetail}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Background="{StaticResource DangerSurfaceBrush}" Padding="10,7" BorderBrush="#6E2A32" BorderThickness="0,1,0,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding DeleteSelectedCommand}"
                                    Content="선택 항목 휴지통으로 이동"
                                    Padding="16,6"
                                    Background="{StaticResource DangerBrush}"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    FontSize="13"/>
                            <TextBlock Text="체크한 항목을 휴지통으로 이동합니다. 삭제 이력은 다음 추천에 로컬로 반영됩니다."
                                       VerticalAlignment="Center"
                                       Foreground="#FFB3B8"
                                       FontSize="11"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="프로젝트 폴더">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="프로젝트 분류" FontSize="13" Margin="0,0,0,12">
                        <ItemsControl ItemsSource="{Binding ProjectTypeItems}" Margin="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,6">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Display}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold"/>
                                        </DockPanel>
                                        <ProgressBar Value="{Binding Percent}"
                                                     Maximum="100"
                                                     Height="16"
                                                     Margin="0,3,0,0"
                                                     Foreground="{Binding BarBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </GroupBox>

                    <GroupBox Grid.Row="1" Header="감지된 프로젝트 폴더" FontSize="13">
                        <DataGrid ItemsSource="{Binding ProjectFolders}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.PanningMode="VerticalOnly"
                                  AlternatingRowBackground="{StaticResource SurfaceAltBrush}"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BorderBrushDark}"
                                  RowHeight="30"
                                  EnableRowVirtualization="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="폴더명" Binding="{Binding Name}" Width="170"/>
                                <DataGridTextColumn Header="분류" Binding="{Binding TypeDescription}" Width="180"/>
                                <DataGridTextColumn Header="기준 폴더" Binding="{Binding SourceName}" Width="130"/>
                                <DataGridTextColumn Header="경로" Binding="{Binding FolderPath}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="저장공간">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <GroupBox Header="드라이브 사용량" Margin="0,0,0,12" FontSize="13">
                            <ItemsControl ItemsSource="{Binding DriveChartItems}" Margin="5">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,6">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Display}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold"/>
                                            </DockPanel>
                                            <ProgressBar Value="{Binding Percent}" Maximum="100" Height="16" Margin="0,3,0,0" Foreground="{Binding BarBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <GroupBox Header="위험 파일 비율" Margin="0,0,0,12" FontSize="13">
                            <ItemsControl ItemsSource="{Binding RiskDistributionItems}" Margin="5">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,6">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Display}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold"/>
                                            </DockPanel>
                                            <ProgressBar Value="{Binding Percent}" Maximum="100" Height="16" Margin="0,3,0,0" Foreground="{Binding BarBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <GroupBox Header="큰 폴더 분석" FontSize="13">
                            <DataGrid ItemsSource="{Binding StorageItems}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      MaxHeight="400"
                                      GridLinesVisibility="Horizontal"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.PanningMode="VerticalOnly"
                                      AlternatingRowBackground="{StaticResource SurfaceAltBrush}"
                                      BorderThickness="1"
                                      BorderBrush="{StaticResource BorderBrushDark}"
                                      RowHeight="30"
                                      EnableRowVirtualization="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="폴더명" Binding="{Binding Name}" Width="150"/>
                                    <DataGridTextColumn Header="경로" Binding="{Binding FolderPath}" Width="*"/>
                                    <DataGridTextColumn Header="크기" Binding="{Binding SizeDisplay}" Width="100"/>
                                    <DataGridTemplateColumn Header="상대 크기" Width="220">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ProgressBar Value="{Binding Percent}"
                                                             Maximum="100"
                                                             Height="16"
                                                             Margin="4,0"
                                                             Foreground="{Binding BarBrush}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="설정">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" Width="520" HorizontalAlignment="Left">
                        <GroupBox Header="정리 프로필" Margin="0,0,0,12">
                            <StackPanel Margin="10">
                                <TextBlock Text="현재 목적에 맞는 정리 방식을 선택하세요." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                <ComboBox ItemsSource="{Binding CleanupProfiles}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Name"
                                          SelectedValue="{Binding Settings.CleanupProfile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Width="180"
                                          HorizontalAlignment="Left"
                                          Margin="0,0,0,8"/>
                                <Border Background="{StaticResource SurfaceAltBrush}"
                                        BorderBrush="{StaticResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10">
                                    <TextBlock Text="{Binding CleanupProfileDescription}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="추천 및 스캔" Margin="0,0,0,12">
                            <StackPanel Margin="10">
                                <TextBlock Text="자동 선택 기준 점수" FontWeight="SemiBold"/>
                                <Slider Minimum="0" Maximum="40" TickFrequency="5" IsSnapToTickEnabled="True"
                                        Value="{Binding Settings.AutoSelectRiskThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="{Binding Settings.AutoSelectRiskThreshold, StringFormat=현재 기준: 낮음 등급 중 {0}점 미만}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>

                                <TextBlock Text="기본 스캔 모드" FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding ScanModes}"
                                          SelectedItem="{Binding Settings.DefaultScanMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Width="160"
                                          HorizontalAlignment="Left"
                                          Margin="0,4,0,10"/>

                                <CheckBox Content="하위 폴더 포함" IsChecked="{Binding Settings.IncludeSubfolders, Mode=TwoWay}" Margin="0,2"/>
                                <CheckBox Content="삭제 이력 기반 추천 우선순위 사용" IsChecked="{Binding Settings.PreferLearnedRecommendations, Mode=TwoWay}" Margin="0,2"/>
                                <CheckBox Content="자세한 진행 상태 표시" IsChecked="{Binding Settings.ShowDetailedProgress, Mode=TwoWay}" Margin="0,2"/>
                            </StackPanel>
                        </GroupBox>

                        <WrapPanel Margin="0,0,0,12">
                            <Button Command="{Binding SaveSettingsCommand}" Content="설정 저장" Padding="12,5" Margin="0,0,6,0"/>
                            <Button Command="{Binding ReloadSettingsCommand}" Content="다시 불러오기" Padding="12,5"/>
                        </WrapPanel>

                        <GroupBox Header="최근 오류 이력">
                            <DockPanel Margin="10">
                                <Button DockPanel.Dock="Top" Command="{Binding RefreshErrorsCommand}" Content="오류 이력 새로고침" Padding="8,4" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                                <ListBox ItemsSource="{Binding RecentErrors}" MaxHeight="260">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2,4">
                                                <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Type}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" Padding="3,0"/>
                    <TextBlock Text="{Binding OperationDetail}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Padding="3,0"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="180"
                             Height="10"
                             Value="{Binding ScanProgress}"
                             Maximum="100"
                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                             Margin="0,0,5,0"
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
